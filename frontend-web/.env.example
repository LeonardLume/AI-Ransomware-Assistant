# Optional override. Prefer VITE_API_PORT for local/LAN use so the browser can
# call the backend on the same hostname that opened the frontend.
# VITE_API_PORT=8000
#
# Use VITE_API_BASE_URL only when the backend is on a separate fixed host.
# Loopback hosts are rewritten to the current LAN hostname when needed.
# VITE_API_BASE_URL=http://127.0.0.1:8000
